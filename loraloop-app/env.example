# ═══════════════════════════════════════════════════════════════
# Loraloop App — Environment Variables
# Copy to .env.local and fill in your keys
# ═══════════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Google Gemini (AI generation) ────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Stripe (billing) ─────────────────────────────────────────
# Keys: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...          # From: stripe listen --forward-to localhost:3000/api/billing/webhook

# Public key (safe to expose to browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Stripe Price IDs ─────────────────────────────────────────
# Create these in Stripe Dashboard > Products > Add Product
# One product per plan, three prices each (monthly / quarterly / annual)

# Solo ($9/mo · $24/quarter · $86/yr)
STRIPE_PRICE_SOLO_MONTHLY=price_...
STRIPE_PRICE_SOLO_QUARTERLY=price_...
STRIPE_PRICE_SOLO_ANNUAL=price_...
NEXT_PUBLIC_STRIPE_PRICE_SOLO_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_SOLO_QUARTERLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_SOLO_ANNUAL=price_...

# Pro ($29/mo · $78/quarter · $278/yr)
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_QUARTERLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_PRO_QUARTERLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_PRO_ANNUAL=price_...

# Agency ($69/mo · $186/quarter · $662/yr)
STRIPE_PRICE_AGENCY_MONTHLY=price_...
STRIPE_PRICE_AGENCY_QUARTERLY=price_...
STRIPE_PRICE_AGENCY_ANNUAL=price_...
NEXT_PUBLIC_STRIPE_PRICE_AGENCY_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_AGENCY_QUARTERLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_AGENCY_ANNUAL=price_...

# Enterprise ($169/mo · $456/quarter · $1622/yr)
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_QUARTERLY=price_...
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_...
NEXT_PUBLIC_STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_ENTERPRISE_QUARTERLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_ENTERPRISE_ANNUAL=price_...
